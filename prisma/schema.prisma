// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  grade     String   // 年级
  avatar    String?  // 头像emoji
  totalPoints Int    @default(0) // 总积分
  streak    Int      @default(0) // 连续学习天数
  lastStudyAt DateTime? // 最后学习时间
  createdAt DateTime @default(now())
  mistakes  Mistake[]
  practices Practice[]
}

model Mistake {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  subject        String    // 语文/数学/英语
  imageUrl       String?   // 上传的图片URL
  content        String    // AI识别的题目内容
  knowledgePoint String    // 知识点
  status         String    @default("NEW") // NEW/PRACTICING/REVIEWING_1/REVIEWING_2/MASTERED
  correctStreak  Int       @default(0) // 连续全对次数
  nextReviewAt   DateTime? // 下次复习时间
  cachedQuestions String?  // JSON: 缓存的AI生成题目
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  practices      Practice[]
}

model Practice {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  mistakeId  String
  mistake    Mistake  @relation(fields: [mistakeId], references: [id])
  questions  String   // JSON: 生成的题目
  answers    String   // JSON: 学生的答案
  score      Int      // 得分
  total      Int      // 总题数
  allCorrect Boolean  // 是否全对
  createdAt  DateTime @default(now())
}
